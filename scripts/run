#!/usr/bin/env bash
# Start DB (async) and server (sync). Safe to re-run (docker compose up is idempotent)
set -eu
cd "$(dirname "${BASH_SOURCE[0]}")/.."
pushd database
docker compose up -d
popd
pushd laravel/lite-app
until [ "$(docker inspect --format='{{.State.Health.Status}}' sae5_6_InTheEnd)" = "healthy" ]; do
    sleep 1
done
php artisan migrate
if [[ "$#" -eq 0 || -z "${1:-}" ]]; then
    composer run dev
else
    composer run "$@"
fi
popd